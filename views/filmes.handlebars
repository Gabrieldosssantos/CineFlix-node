<header class="w-full h-[420px] bg-cover bg-center" style="background-image: url('/assets/Banner.png');">
  <div class="w-full h-full flex flex-col justify-center items-center bg-black/60">

  

  </div>
</header>


<h2 class="text-2xl md:text-5xl font-bold text-center mt-9 mb-6">
  Lista de Filmes
</h2>


<div id="menu" class="max-w-4xl mx-auto px-4">
  <main>

    {{#each filmes}}
      <div class="relative flex gap-4 mb-6 bg-white p-4 rounded-lg shadow hover:shadow-xl transition-shadow duration-300 border border-gray-100">

        <img src="{{this.imagem}}" alt="{{this.titulo}}"
          class="w-28 h-28 rounded-md hover:scale-110 hover:-rotate-2 duration-200 object-cover">

        <div class="flex-1">
          <div class="flex justify-between items-start">
            <p class="font-bold text-xl text-gray-900">
              {{this.titulo}}
            </p>

            <div class="flex items-center gap-2">
              {{#if this.trailer}}
                <a href="{{this.trailer}}" target="_blank"
                  class="bg-gray-900 text-white px-3 py-1.5 rounded-md text-sm font-semibold flex items-center gap-2 hover:bg-gray-700 transition duration-200"
                  title="Ver Trailer">
                  <i class="fa-solid fa-play"></i> Trailer
                </a>
              {{else}}
                <span class="text-xs uppercase tracking-wider px-3 py-1.5 rounded-md bg-gray-200 text-gray-500">
                  Sem trailer
                </span>
              {{/if}}

              <form action="/filmes/remover/{{this.id}}" method="POST"
                onsubmit="return confirm('Tem certeza que deseja remover este filme?')">
                <button type="submit"
                  class="bg-gray-900 text-white px-3 py-1.5 rounded-md text-sm font-semibold hover:bg-red-800 transition duration-200"
                  title="Remover Filme">
                  <i class="fa-solid fa-trash"></i> Remover
                </button>
              </form>
            </div>
          </div>

          <p class="text-base text-gray-700 leading-relaxed mt-2 italic">
            "{{this.descricao}}"
          </p>

          <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-2 p-3 bg-gray-50 rounded-lg border border-gray-200">
            <p class="text-sm text-gray-700">
              🎬 <span class="font-bold">Diretor:</span> <span class="text-blue-600">{{this.diretor}}</span>
            </p>

            <p class="text-sm text-gray-700">
              📅 <span class="font-bold">Lançamento:</span> {{this.dataLancamento}}
            </p>

            <p class="text-sm text-gray-700 md:col-span-2">
              🎭 <span class="font-bold">Gênero:</span> {{this.genero}}
            </p>
          </div>
        </div>

      </div>
    {{/each}}

  </main>
</div>

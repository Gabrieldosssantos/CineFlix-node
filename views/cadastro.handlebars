<div class="min-h-screen bg-gradient-to-br from-gray-900 via-gray-800 to-black flex items-center justify-center px-4 py-10">

  <div class="w-full max-w-lg bg-white rounded-2xl shadow-2xl p-8 border border-gray-200">

    
    <h2 class="text-4xl font-extrabold text-center text-gray-800 mb-6">
      🎬 Cadastro de Filme
    </h2>

    <p class="text-center text-gray-500 mb-6">
      Preencha os dados para adicionar um novo filme ao catálogo
    </p>

    <form action="/filmes" method="POST" enctype="multipart/form-data" class="space-y-5">

      
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">
          Título do filme
        </label>

        <input
          type="text"
          name="titulo"
          placeholder="Ex: Toy Story 5"
          class="w-full rounded-lg border border-gray-300 px-3 py-2
          focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none
          transition"
        >
      </div>

      
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">
          Diretor
        </label>

        <input
          type="text"
          name="diretor"
          placeholder="Ex: Andrew Stanton"
          class="w-full rounded-lg border border-gray-300 px-3 py-2
          focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"
        >
      </div>

      
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">
          Gênero
        </label>

        <input
          type="text"
          name="genero"
          placeholder="Ação, Comédia, Drama"
          class="w-full rounded-lg border border-gray-300 px-3 py-2
          focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"
        >
      </div>

      
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">
          Data de lançamento
        </label>

        <input
          type="date"
          name="lancamento"
          class="w-full rounded-lg border border-gray-300 px-3 py-2
          focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"
        >
      </div>

      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">
          Sinopse
        </label>

        <textarea
          name="sinopse"
          rows="4"
          placeholder="Descreva a sinopse do filme..."
          class="w-full rounded-lg border border-gray-300 px-3 py-2
          focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none
          transition"
        ></textarea>
      </div>

      
      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">
          Link do Trailer (YouTube)
        </label>

        <input
          type="url"
          name="trailer"
          placeholder="Ex: https://www.youtube.com/watch?v=..."
          class="w-full rounded-lg border border-gray-300 px-3 py-2
          focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none
          transition"
        >
      </div>

      <div>
        <label class="block text-sm font-semibold text-gray-700 mb-1">
          Capa do filme
        </label>

        <input
          type="file"
          name="foto"
          accept="image/*"
          class="w-full rounded-lg border border-gray-300 px-3 py-2
          file:bg-blue-600 file:text-white file:px-4 file:py-2
          file:rounded file:border-0
          hover:file:bg-blue-700"
        >
      </div>

      
      <button
        type="submit"
        class="w-full bg-gradient-to-r from-blue-600 to-indigo-600
        text-white font-bold py-3 rounded-lg
        hover:scale-105 hover:from-blue-700 hover:to-indigo-700
        transition duration-200 shadow-lg"
      >
        🚀 Cadastrar Filme
      </button>

    </form>

  </div>

</div>